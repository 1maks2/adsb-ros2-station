AMENT_PREFIX_PATH=/opt/ros/jazzy
COLCON=1
HOME=/root
HOSTNAME=maks-desktop
LANG=C.UTF-8
LC_ALL=C.UTF-8
LD_LIBRARY_PATH=/opt/ros/jazzy/lib/aarch64-linux-gnu:/opt/ros/jazzy/lib
OLDPWD=/ros2_ws
PATH=/opt/ros/jazzy/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
PWD=/ros2_ws/build/aircraft_tracker
PYTHONPATH=/opt/ros/jazzy/lib/python3.12/site-packages
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_AUTOMATIC_DISCOVERY_RANGE=SUBNET
ROS_DISTRO=jazzy
ROS_DOMAIN_ID=0
ROS_PYTHON_VERSION=3
ROS_VERSION=2
SHLVL=1
TERM=xterm
_=/usr/bin/colcon
